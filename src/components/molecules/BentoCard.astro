---
import Icon from '../../components/atoms/Icon.astro';

interface Props {
  icon: 'pos' | 'nexo' | 'auto';
  title: string;
  description: string;
  features: string[];
  delay?: string;
}

const { icon, title, description, features, delay = '0' } = Astro.props;
---

<div 
  class="bento-card p-6 hover:shadow-xl hover:shadow-carbon/[0.05] transition-all duration-500 group"
  data-animate
  data-delay={delay}
>
  <div class="flex items-start justify-between mb-4">
    <div class="p-3 bg-accent-gradient/10 rounded-bento text-accent-teal group-hover:text-accent-indigo transition-colors duration-300">
      <Icon name={icon} class="w-6 h-6" />
    </div>
  </div>
  
  <h3 class="text-xl font-display font-bold tracking-editorial mb-2">{title}</h3>
  <p class="text-carbon/70 mb-4 leading-relaxed">{description}</p>
  
  <ul class="space-y-2">
    {features.map((feature) => (
      <li class="flex items-center gap-2 text-sm">
        <Icon name="check" class="text-accent-teal flex-shrink-0" />
        <span class="text-carbon/80">{feature}</span>
      </li>
    ))}
  </ul>
</div>
