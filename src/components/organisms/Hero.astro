---
import { content } from '../../data/content';
import Button from '../../components/atoms/Button.astro';
---

<section class="relative min-h-screen flex items-center justify-center px-6 py-24 overflow-hidden">
  <!-- Background decorative element -->
  <div class="absolute top-0 right-0 w-1/3 h-1/3 bg-accent-gradient/5 rounded-bento blur-3xl" />
  
  <div class="relative max-w-5xl mx-auto text-center">
    <div data-animate>
      <span class="inline-block px-4 py-2 mb-6 text-xs font-mono tracking-metadata uppercase border border-carbon/[0.12] rounded-full text-carbon/70">
        {content.hero.eyebrow}
      </span>
    </div>
    
    <h1 
      class="text-5xl md:text-7xl lg:text-8xl font-display font-bold tracking-editorial mb-8 leading-tight"
      data-animate
      data-delay="1"
    >
      {content.hero.title}
    </h1>
    
    <p 
      class="text-lg md:text-xl text-carbon/70 max-w-2xl mx-auto mb-12 leading-relaxed"
      data-animate
      data-delay="2"
    >
      {content.hero.subtitle}
    </p>
    
    <div 
      class="flex flex-col sm:flex-row items-center justify-center gap-4"
      data-animate
      data-delay="3"
    >
      <Button text={content.hero.ctaPrimary} variant="primary" href="#whiteglove" />
      <Button text={content.hero.ctaSecondary} variant="secondary" href="#ecosystem" />
    </div>
  </div>
  
  <!-- Scroll indicator -->
  <div 
    class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-60 anim-pulse"
    data-animate
    data-delay="4"
  >
    <div class="w-px h-16 bg-carbon/30" />
  </div>
</section>
