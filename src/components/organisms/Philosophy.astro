---
import { content } from '../../data/content';
import SectionTag from '../../components/atoms/SectionTag.astro';
import FlowNode from '../../components/molecules/FlowNode.astro';
---

<section class="px-6 py-24 bg-white/30">
  <div class="max-w-7xl mx-auto">
    <div class="mb-16" data-animate>
      <SectionTag text={content.philosophy.sectionTag} />
      <h2 class="text-4xl md:text-5xl font-display font-bold tracking-editorial mt-6">
        {content.philosophy.title}
      </h2>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <FlowNode
        label={content.philosophy.oldFlow.label}
        items={content.philosophy.oldFlow.pains}
        type="old"
        delay="1"
      />
      <FlowNode
        label={content.philosophy.newFlow.label}
        items={content.philosophy.newFlow.gains}
        type="new"
        delay="2"
      />
    </div>
  </div>
</section>
